<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/colorPrimary"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.pages.index.AppEntryScreenSplash">

    <Button
        android:id="@+id/btnRetry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        android:text="@string/retry"
        app:layout_constraintEnd_toEndOf="@+id/tvRetryMessage"
        app:layout_constraintStart_toStartOf="@+id/tvRetryMessage"
        app:layout_constraintTop_toBottomOf="@+id/tvRetryMessage" />

    <TextView
        android:id="@+id/tvRetryMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:text="@string/still_checking_your_session_nplease_check_your_internet_connection"
        android:textColor="@color/whiten"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/handworks_logo" />

    <ImageView
        android:id="@+id/handworks_logo"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginBottom="110dp"
        android:contentDescription="@string/handworks_logo"
        android:src="@drawable/handworks_logo_v2"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/progressBarLoading"
        style="@android:style/Widget.DeviceDefault.Light.ProgressBar.Large"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:layout_constraintBottom_toBottomOf="@+id/handworks_logo"
        app:layout_constraintEnd_toEndOf="@+id/handworks_logo"
        app:layout_constraintStart_toStartOf="@+id/handworks_logo" />

    <include
        android:id="@+id/errorUI"
        layout="@layout/activity_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="140dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>